# Sample env template for the shop exemplar.
#
# Copy to `.env` (gitignored). The dotenv import in playwright.config.ts
# is commented out by default — uncomment it to have forge load this file
# on each spec run, or load the same keys via direnv / dotenv-cli / shell
# exports / your secrets manager.
#
# The values below are the seeded demo credentials for
# practicesoftwaretesting.com, documented in the demo's official docs.
# Treat them as fixtures for the public demo, not as real secrets.

# --- customer (standard test account) ---
PST_CUSTOMER_EMAIL=customer@practicesoftwaretesting.com
PST_CUSTOMER_PASSWORD=welcome01

# --- customer2 (second seat for parallel runs) ---
PST_CUSTOMER2_EMAIL=customer2@practicesoftwaretesting.com
PST_CUSTOMER2_PASSWORD=welcome01

# --- admin (admin dashboard, exempt from account-lockout) ---
PST_ADMIN_EMAIL=admin@practicesoftwaretesting.com
PST_ADMIN_PASSWORD=welcome01
