# Sample env for the shop exemplar.
#
# These keys map to the test accounts documented in forge/hints/forge.md.
# Copy this file to `forge/.env` if you want forge to load it on each spec
# run — uncomment `import 'dotenv/config'` in forge/playwright.config.ts to
# enable that path. Or set the same keys via direnv / dotenv-cli / manual
# shell exports / your secrets manager. Forge takes no opinion on how
# values reach process.env; it just expects them to be there.
#
# The demo at practicesoftwaretesting.com seeds these accounts. Treat the
# passwords as fixtures for a public demo, not as real secrets — but
# practise the discipline of keeping them out of tool-call transcripts via
# native shell expansion ($KEY) in your Bash commands. The driver agent
# prompt documents the full rule.

# --- customer (standard test account) ---
PST_CUSTOMER_EMAIL=customer@practicesoftwaretesting.com
PST_CUSTOMER_PASSWORD=welcome01

# --- customer2 (second seat for parallel runs) ---
PST_CUSTOMER2_EMAIL=customer2@practicesoftwaretesting.com
PST_CUSTOMER2_PASSWORD=welcome01

# --- admin (admin dashboard, exempt from account-lockout) ---
PST_ADMIN_EMAIL=admin@practicesoftwaretesting.com
PST_ADMIN_PASSWORD=welcome01
